#!/bin/bash

# 1. Verificar que se pasaron los 3 parámetros
if [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then
    echo "⚠️ Error: Faltan parámetros."
    echo "💡 Uso: forward-codespace \"NOMBRE_DEL_CODESPACE\" <puerto-remoto> <puerto-local>"
    echo "Ejemplo: forward-codespace \"SERVER-A\" 8080 3000"
    exit 1
fi

DISPLAY_NAME="$1"
PUERTO_REMOTO="$2"
PUERTO_LOCAL="$3"

echo "Abriendo túnel: Puerto remoto $PUERTO_REMOTO ➡️ Puerto local $PUERTO_LOCAL en '$DISPLAY_NAME'..."

# 2. Ejecutar el comando inyectando los puertos y el subcomando de búsqueda
gh codespace ports forward "$PUERTO_REMOTO:$PUERTO_LOCAL" -c $(gh codespace list --json name,displayName --jq ".[] | select(.displayName==\"$DISPLAY_NAME\") | .name")
